# ============================================================
# ServLink Data Engine - Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.
# For GitHub Actions, configure these as Repository Secrets.
# ============================================================

# --- Supabase (Required) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key_here

# --- Overpass API (Optional, has default) ---
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# --- SearXNG (Required for SERP extraction) ---
SEARXNG_URL=https://your-searxng-instance.example.com

# --- Outscraper (Future - Paid) ---
# OUTSCRAPER_API_KEY=your_outscraper_api_key

# --- LLM Classification (Optional) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Logging ---
LOG_LEVEL=INFO
